  <!--  FREE TOOLS – Track Auto Color                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <category name="Tools/JG_Track_Auto_Color">

    <reapack name="JG_Track_Auto_Color.lua" type="script" desc="JG Track Auto Color">
      <version name="1.0.0" author="Julius Gass">
        <changelog><![CDATA[Initial release]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="1.0.1" author="Julius Gass">
        <changelog><![CDATA[Embed JSON library directly (fix ReaPack install)]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="1.0.2" author="Julius Gass">
        <changelog><![CDATA[Fix ImGui_PushFont missing font size argument]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="1.1.0" author="Julius Gass">
        <changelog><![CDATA[Fix color picker (was using wrong format), auto-coloring, English UI, case-insensitive aliases]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="1.2.0" author="Julius Gass">
        <changelog><![CDATA[Add case rules (ALL UPPERCASE / all lowercase) with highest priority, remove skip folders option]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="1.3.0" author="Julius Gass">
        <changelog><![CDATA[Replace case rules with uppercase darkening: UPPERCASE tracks get their resolved color darkened by configurable %. Children inherit the undarkened color.]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.0.0" author="Julius Gass">
        <changelog><![CDATA[Major restructure: remove top-level rules (modules only), remove parent filter, remove tabs (flat UI), comma-separated rule pattern aliases, per-module folder darken slider (replaces fixed folder color), tracks without folder context match all modules in order]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.1.0" author="Julius Gass">
        <changelog><![CDATA[Module color as central color source, per-rule "use module color" toggle (default on), remove uppercase darkening, folder aliases as comma-separated string, module folder gets darkened module color (default 10%), migration from v2.0 data]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.2.0" author="Julius Gass">
        <changelog><![CDATA[Module name = first alias (no separate name field), stale P_EXT cleanup on each engine run, random colors for unmatched tracks (optional), folder darken default 0, orphaned file cleanup on save]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.2.1" author="Julius Gass">
        <changelog><![CDATA[Show 0xRRGGBB hex code next to color pickers]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.3.0" author="Julius Gass">
        <changelog><![CDATA[Drag & drop reordering for rules and modules, visible color picker with hex input, Sort A-Z for rules, new rules default to module color, reset track color when moved out of folder]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.4.0" author="Julius Gass">
        <changelog><![CDATA[Auto specificity sorting: engine matches exact > starts_with/ends_with > contains, longer patterns first. GUI shows rules alphabetically. Manual rule reordering removed.]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.4.1" author="Julius Gass">
        <changelog><![CDATA[Fix child inheritance: user-colored tracks now reliably pass their color to children. New rules stay at bottom, stable ImGui IDs for empty rules.]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.4.2" author="Julius Gass">
        <changelog><![CDATA[Fix black track bug: use I_CUSTOMCOLOR to properly reset to theme default. Remove random_unmatched option.]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.4.3" author="Julius Gass">
        <changelog><![CDATA[Fix crash when collapsing window (ImGui_End only when Begin returns true)]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.5.0" author="Julius Gass">
        <changelog><![CDATA[Background mode: script runs continuously for auto-coloring without GUI. Run action again to toggle GUI. Close window hides GUI but keeps engine running. Works with SWS startup actions.]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
      <version name="2.5.1" author="Julius Gass">
        <changelog><![CDATA[Fix invalid ImGui context when toggling GUI back on after background mode. Add Stop button. Lazy context creation.]]></changelog>
        <source main="main">https://raw.githubusercontent.com/audio-guy/JG_Scripts/main/Tools/JG_Track_Auto_Color/JG_Track_Auto_Color.lua</source>
      </version>
    </reapack>

    <reapack name="JG_Track_Auto_Color_Toggle_GUI.lua" type="script" desc="JG Track Auto Color - Toggle GUI">
      <version name="1.0.0" author="Julius Gass">
